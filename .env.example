# Supabase — create a project at https://supabase.com
# Copy this file to .env.local and fill in your values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini — AI Doctor photo analysis (REQUIRED for real diagnosis)
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenWeather (optional — for weather / spray window)
OPENWEATHER_API_KEY=your-openweather-key

# Firebase Phone Auth — https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789

# Capacitor Android WebView target (LAN IP or production URL)
# Example: http://192.168.1.10:3000  or  https://your-app.vercel.app
CAPACITOR_SERVER_URL=
