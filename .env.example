# Supabase — create a project at https://supabase.com
# Copy this file to .env.local and fill in your values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini — AI Doctor photo analysis (REQUIRED for real diagnosis)
# Free key: https://aistudio.google.com/apikey
# New accounts get AQ.xxx auth keys; older keys start with AIzaSy — both work.
GEMINI_API_KEY=

# data.gov.in — live mandi prices (optional)
# Register at https://data.gov.in and create an API key
DATA_GOV_API_KEY=

# OpenWeather (optional — for weather / spray window)
OPENWEATHER_API_KEY=your-openweather-key

# Firebase Phone Auth
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789

# Capacitor Android WebView target (LAN IP or production URL)
# Play Store: use your Vercel HTTPS URL, e.g. https://agriveda.vercel.app
# Example: http://192.168.1.10:3000  or  https://your-app.vercel.app
CAPACITOR_SERVER_URL=

# ─── Play Store minimum (set on Vercel + local .env.local) ───
# GEMINI_API_KEY=          # required for AI Doctor on production
# OPENWEATHER_API_KEY=     # recommended for live weather
# DATA_GOV_API_KEY=        # optional — live mandi prices
